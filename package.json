{
  "name": "runjs-clone",
  "private": true,
  "version": "1.0.0",
  "description": "A premium, high-performance JS/TS playground inspired by RunJS with integrated AI capabilities.",
  "author": "Martiris Guzman",
  "license": "MIT",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev:ui": "vite",
    "dev:electron": "tsc -w -p tsconfig.node.json",
    "dev:start": "node start-electron.js",
    "dev": "concurrently -k \"npm run dev:ui\" \"npm run dev:electron\" \"npm run dev:start\"",
    "build": "tsc -b && vite build && tsc -p tsconfig.node.json",
    "dist": "npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.martiris.runnerjs",
    "productName": "RunnerJS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "@babel/standalone": "^7.29.1",
    "@monaco-editor/react": "^4.7.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-split": "^2.0.14",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "sucrase": "^3.35.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/babel__standalone": "^7.1.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
